{
    "metadata": {
        "version": "1.0.0",
        "description": "Algebra misconception knowledge graph for adaptive tutoring",
        "source": "MaE Dataset (Otero et al., 2024, arXiv:2412.03765)",
        "created": "2026-03-22",
        "mastery_threshold": 0.85,
        "mastery_initial": 0.5
    },
    "concepts": [
        {
            "id": "integer_sign_ops",
            "name": "Integer & Sign Operations",
            "description": "Arithmetic with negative numbers: addition, subtraction, multiplication, division with signed integers.",
            "level": 1,
            "prerequisites": [],
            "mae_ids": [
                "MaE06",
                "MaE07",
                "MaE08",
                "MaE09",
                "MaE10"
            ],
            "bkt_params": {
                "p_init": 0.15,
                "p_learn": 0.15,
                "p_guess": 0.10,
                "p_slip": 0.10
            },
            "misconceptions": [
                {
                    "id": "sign_sum_negatives",
                    "label": "Sum of negatives becomes positive",
                    "description": "Student adds two negative numbers and gets a positive result.",
                    "examples": [
                        {
                            "problem": "Simplify: -6 - 3",
                            "wrong": "9",
                            "correct": "-9"
                        },
                        {
                            "problem": "Simplify: -5 - 4",
                            "wrong": "9",
                            "correct": "-9"
                        }
                    ]
                },
                {
                    "id": "sign_neg_times_neg",
                    "label": "Negative times negative gives negative",
                    "description": "Student multiplies two negatives and keeps the result negative.",
                    "examples": [
                        {
                            "problem": "Simplify: -3 × (-4)",
                            "wrong": "-12",
                            "correct": "12"
                        },
                        {
                            "problem": "Simplify: -2 × (-5)",
                            "wrong": "-10",
                            "correct": "10"
                        }
                    ]
                },
                {
                    "id": "sign_sub_negative",
                    "label": "Subtracting a negative treated as subtraction",
                    "description": "Student treats subtraction of a negative as regular subtraction instead of addition.",
                    "examples": [
                        {
                            "problem": "Simplify: 5 - (-3)",
                            "wrong": "2",
                            "correct": "8"
                        },
                        {
                            "problem": "Simplify: 10 - (-2)",
                            "wrong": "8",
                            "correct": "12"
                        }
                    ]
                },
                {
                    "id": "sign_always_subtract_smaller",
                    "label": "Always subtract smaller from larger",
                    "description": "Student ignores sign and subtracts the smaller absolute value from the larger, getting a positive result.",
                    "examples": [
                        {
                            "problem": "Simplify: 3 - 7",
                            "wrong": "4",
                            "correct": "-4"
                        },
                        {
                            "problem": "Simplify: 2 - 9",
                            "wrong": "7",
                            "correct": "-7"
                        }
                    ]
                }
            ]
        },
        {
            "id": "order_of_operations",
            "name": "Order of Operations",
            "description": "Evaluating expressions using correct precedence: parentheses, exponents, multiplication/division, addition/subtraction.",
            "level": 2,
            "prerequisites": [
                "integer_sign_ops"
            ],
            "mae_ids": [
                "MaE20",
                "MaE21",
                "MaE22",
                "MaE31"
            ],
            "bkt_params": {
                "p_init": 0.10,
                "p_learn": 0.10,
                "p_guess": 0.10,
                "p_slip": 0.15
            },
            "misconceptions": [
                {
                    "id": "oo_left_to_right",
                    "label": "Left-to-right ignoring precedence",
                    "description": "Student evaluates strictly left-to-right without respecting multiplication/division before addition/subtraction.",
                    "examples": [
                        {
                            "problem": "Evaluate: 2 + 3 × 4",
                            "wrong": "20",
                            "correct": "14"
                        },
                        {
                            "problem": "Evaluate: 10 - 2 × 3",
                            "wrong": "24",
                            "correct": "4"
                        }
                    ]
                },
                {
                    "id": "oo_exponent_after_add",
                    "label": "Exponents applied after addition",
                    "description": "Student adds before applying the exponent.",
                    "examples": [
                        {
                            "problem": "Evaluate: 3 + 4²",
                            "wrong": "49",
                            "correct": "19"
                        },
                        {
                            "problem": "Evaluate: 1 + 2³",
                            "wrong": "27",
                            "correct": "9"
                        }
                    ]
                },
                {
                    "id": "oo_parentheses_ignored",
                    "label": "Parentheses ignored",
                    "description": "Student ignores grouping symbols and evaluates in default order.",
                    "examples": [
                        {
                            "problem": "Evaluate: (2 + 3) × 4",
                            "wrong": "14",
                            "correct": "20"
                        },
                        {
                            "problem": "Evaluate: 6 ÷ (1 + 2)",
                            "wrong": "5",
                            "correct": "2"
                        }
                    ]
                }
            ]
        },
        {
            "id": "distributive_property",
            "name": "Distributive Property",
            "description": "Applying a(b + c) = ab + ac, including distributing negatives and factoring as reverse distribution.",
            "level": 3,
            "prerequisites": [
                "order_of_operations"
            ],
            "mae_ids": [
                "MaE31",
                "MaE32",
                "MaE33",
                "MaE34"
            ],
            "bkt_params": {
                "p_init": 0.05,
                "p_learn": 0.15,
                "p_guess": 0.05,
                "p_slip": 0.10
            },
            "misconceptions": [
                {
                    "id": "dist_first_term_only",
                    "label": "Only distribute to first term",
                    "description": "Student multiplies the factor by the first term inside parentheses but leaves the second term unchanged.",
                    "examples": [
                        {
                            "problem": "Expand: 2(x + 3)",
                            "wrong": "2x + 3",
                            "correct": "2x + 6"
                        },
                        {
                            "problem": "Expand: 4(y + 5)",
                            "wrong": "4y + 5",
                            "correct": "4y + 20"
                        }
                    ]
                },
                {
                    "id": "dist_square_over_addition",
                    "label": "Square distributes over addition",
                    "description": "Student applies an exponent to each term separately, missing the cross-term.",
                    "examples": [
                        {
                            "problem": "Expand: (x + 2)²",
                            "wrong": "x² + 4",
                            "correct": "x² + 4x + 4"
                        },
                        {
                            "problem": "Expand: (a + 3)²",
                            "wrong": "a² + 9",
                            "correct": "a² + 6a + 9"
                        }
                    ]
                },
                {
                    "id": "dist_sign_error_negative",
                    "label": "Sign error when distributing negative",
                    "description": "Student distributes the magnitude but does not flip the sign on the second term.",
                    "examples": [
                        {
                            "problem": "Expand: -3(x - 4)",
                            "wrong": "-3x - 12",
                            "correct": "-3x + 12"
                        },
                        {
                            "problem": "Expand: -2(a - 5)",
                            "wrong": "-2a - 10",
                            "correct": "-2a + 10"
                        }
                    ]
                },
                {
                    "id": "dist_drop_parens",
                    "label": "Drop parentheses without distributing",
                    "description": "Student removes parentheses but only multiplies the first term, treating the operation as if parentheses were decorative.",
                    "examples": [
                        {
                            "problem": "Expand: 5(x + 1)",
                            "wrong": "5x + 1",
                            "correct": "5x + 5"
                        },
                        {
                            "problem": "Expand: 3(m + 7)",
                            "wrong": "3m + 7",
                            "correct": "3m + 21"
                        }
                    ]
                }
            ]
        },
        {
            "id": "combining_like_terms",
            "name": "Combining Like Terms",
            "description": "Identifying terms with the same variable and exponent, then adding or subtracting their coefficients.",
            "level": 4,
            "prerequisites": [
                "distributive_property"
            ],
            "mae_ids": [
                "MaE45",
                "MaE46",
                "MaE47",
                "MaE48"
            ],
            "bkt_params": {
                "p_init": 0.10,
                "p_learn": 0.20,
                "p_guess": 0.05,
                "p_slip": 0.10
            },
            "misconceptions": [
                {
                    "id": "clt_combine_unlike",
                    "label": "Combine unlike terms",
                    "description": "Student adds terms with different variables by concatenating or merging them.",
                    "examples": [
                        {
                            "problem": "Simplify: 3x + 2y",
                            "wrong": "5xy",
                            "correct": "3x + 2y (cannot combine)"
                        },
                        {
                            "problem": "Simplify: 4a + 3b",
                            "wrong": "7ab",
                            "correct": "4a + 3b (cannot combine)"
                        }
                    ]
                },
                {
                    "id": "clt_multiply_variables",
                    "label": "Multiply variables when combining",
                    "description": "Student combines coefficients correctly but also multiplies the variable parts (e.g., x + x = x²).",
                    "examples": [
                        {
                            "problem": "Simplify: 2x + 3x",
                            "wrong": "5x²",
                            "correct": "5x"
                        },
                        {
                            "problem": "Simplify: x + x",
                            "wrong": "x²",
                            "correct": "2x"
                        }
                    ]
                },
                {
                    "id": "clt_constant_as_variable",
                    "label": "Treat constants as like terms with variables",
                    "description": "Student combines a constant with a variable term as if they were like terms.",
                    "examples": [
                        {
                            "problem": "Simplify: 5x + 3",
                            "wrong": "8x",
                            "correct": "5x + 3 (cannot combine)"
                        },
                        {
                            "problem": "Simplify: 2y + 7",
                            "wrong": "9y",
                            "correct": "2y + 7 (cannot combine)"
                        }
                    ]
                },
                {
                    "id": "clt_add_exponents",
                    "label": "Add exponents when combining",
                    "description": "Student adds the exponents of like terms instead of keeping them the same.",
                    "examples": [
                        {
                            "problem": "Simplify: 2x² + 3x²",
                            "wrong": "5x⁴",
                            "correct": "5x²"
                        },
                        {
                            "problem": "Simplify: x³ + 4x³",
                            "wrong": "5x⁶",
                            "correct": "5x³"
                        }
                    ]
                }
            ]
        },
        {
            "id": "solving_linear_equations",
            "name": "Solving Linear Equations",
            "description": "Isolating the variable in one-step, two-step, and multi-step linear equations using inverse operations.",
            "level": 5,
            "prerequisites": [
                "combining_like_terms"
            ],
            "mae_ids": [
                "MaE49",
                "MaE50",
                "MaE51",
                "MaE52",
                "MaE53",
                "MaE54",
                "MaE55"
            ],
            "bkt_params": {
                "p_init": 0.05,
                "p_learn": 0.10,
                "p_guess": 0.05,
                "p_slip": 0.10
            },
            "misconceptions": [
                {
                    "id": "leq_reverse_operation",
                    "label": "Apply same operation instead of inverse",
                    "description": "Student adds when they should subtract (or vice versa) to isolate the variable.",
                    "examples": [
                        {
                            "problem": "Solve: x + 5 = 12",
                            "wrong": "x = 17",
                            "correct": "x = 7"
                        },
                        {
                            "problem": "Solve: x - 3 = 10",
                            "wrong": "x = 7",
                            "correct": "x = 13"
                        }
                    ]
                },
                {
                    "id": "leq_divide_wrong_direction",
                    "label": "Multiply instead of divide",
                    "description": "Student multiplies by the coefficient instead of dividing.",
                    "examples": [
                        {
                            "problem": "Solve: 3x = 12",
                            "wrong": "x = 36",
                            "correct": "x = 4"
                        },
                        {
                            "problem": "Solve: 5x = 25",
                            "wrong": "x = 125",
                            "correct": "x = 5"
                        }
                    ]
                },
                {
                    "id": "leq_subtract_wrong_side",
                    "label": "Operate on wrong side of equation",
                    "description": "Student applies the inverse operation to the wrong side, breaking the equality.",
                    "examples": [
                        {
                            "problem": "Solve: 2x + 3 = 11",
                            "wrong": "2x = 14, x = 7",
                            "correct": "2x = 8, x = 4"
                        },
                        {
                            "problem": "Solve: 4x + 1 = 17",
                            "wrong": "4x = 18, x = 4.5",
                            "correct": "4x = 16, x = 4"
                        }
                    ]
                },
                {
                    "id": "leq_move_without_sign_change",
                    "label": "Move term without changing sign",
                    "description": "Student moves a term across the equals sign without flipping its sign.",
                    "examples": [
                        {
                            "problem": "Solve: x - 4 = 10",
                            "wrong": "x = 10 - 4 = 6",
                            "correct": "x = 14"
                        },
                        {
                            "problem": "Solve: x - 7 = 3",
                            "wrong": "x = 3 - 7 = -4",
                            "correct": "x = 10"
                        }
                    ]
                }
            ]
        }
    ],
    "edges": [
        {
            "from": "integer_sign_ops",
            "to": "order_of_operations",
            "type": "prerequisite"
        },
        {
            "from": "order_of_operations",
            "to": "distributive_property",
            "type": "prerequisite"
        },
        {
            "from": "distributive_property",
            "to": "combining_like_terms",
            "type": "prerequisite"
        },
        {
            "from": "combining_like_terms",
            "to": "solving_linear_equations",
            "type": "prerequisite"
        }
    ]
}